{
  "name": "researchvy",
  "version": "0.1.0",
  "private": true,
  "description": "Researcher Visibility Intelligence Platform",
  "packageManager": "pnpm@9.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev":             "turbo run dev",
    "dev:api":         "turbo run dev --filter=@researchvy/api",
    "dev:web":         "turbo run dev --filter=@researchvy/web",
    "build":           "turbo run build",
    "typecheck":       "turbo run typecheck",
    "lint":            "turbo run lint",
    "test":            "turbo run test",
    "clean":           "turbo run clean && rm -rf node_modules",
    "db:generate":     "prisma generate --schema=apps/api/prisma/schema.prisma",
    "db:migrate":      "prisma migrate dev --schema=apps/api/prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:seed":         "tsx apps/api/prisma/seed.ts",
    "db:studio":       "prisma studio --schema=apps/api/prisma/schema.prisma",
    "db:reset":        "prisma migrate reset --force --schema=apps/api/prisma/schema.prisma"
  },
  "devDependencies": {
    "turbo": "^2.0.6",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@prisma/client": "5.22.0",
    "prisma": "5.22.0",
    "tsx": "^4.10.5",
    "@types/node": "^20.12.12"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
