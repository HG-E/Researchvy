{
  // Shared TypeScript base config — extended by apps/api, apps/web, packages/shared
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,                    // Enable all strict checks — no shortcuts
    "exactOptionalPropertyTypes": true, // Distinguish undefined vs missing
    "noUncheckedIndexedAccess": true,  // Array[i] returns T | undefined
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "exclude": ["node_modules", "dist", "build", ".next"]
}
