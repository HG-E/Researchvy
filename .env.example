# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://researchvy:researchvy_secret@localhost:5432/researchvy_dev"

# ─────────────────────────────────────────────
# REDIS (optional, for job queues + caching)
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# API SERVER
# ─────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# JWT secret — generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here_replace_in_production
JWT_EXPIRY=7d

# ─────────────────────────────────────────────
# ORCID OAuth2
# Register at: https://orcid.org/developer-tools
# Use sandbox for dev: https://sandbox.orcid.org/developer-tools
# ─────────────────────────────────────────────
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=your_orcid_client_secret
ORCID_REDIRECT_URI=http://localhost:3000/auth/orcid/callback
# Use "https://orcid.org" for production, "https://sandbox.orcid.org" for dev
ORCID_BASE_URL=https://sandbox.orcid.org
ORCID_API_URL=https://pub.sandbox.orcid.org

# ─────────────────────────────────────────────
# OPENALEX API
# Free, no API key required — but add email for polite pool (higher rate limits)
# Docs: https://docs.openalex.org
# ─────────────────────────────────────────────
OPENALEX_EMAIL=your_email@example.com

# ─────────────────────────────────────────────
# SEMANTIC SCHOLAR API
# Free tier: 100 req/5min unauthenticated, 1/s authenticated
# Docs: https://api.semanticscholar.org/api-docs
# ─────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=

# ─────────────────────────────────────────────
# NEXT.JS FRONTEND
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# ─────────────────────────────────────────────
# ENCRYPTION (for storing ORCID tokens at rest)
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────
ENCRYPTION_KEY=your_32_byte_hex_key_here
