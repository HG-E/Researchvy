# .npmrc
# Enforces pnpm as the package manager for this monorepo.

# Prevents accidentally installing with npm or yarn
engine-strict=true

# Hoist shared devDependencies (typescript, eslint) to root node_modules
# so each app doesn't need its own copy — saves disk space
shamefully-hoist=false
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/*
